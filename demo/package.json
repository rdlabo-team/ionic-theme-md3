{
  "name": "demo",
  "version": "0.0.1",
  "author": "Ionic Framework",
  "homepage": "https://ionicframework.com/",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:update": "playwright test --update-snapshots",
    "test:e2e:docker": "docker run --rm -v $(pwd)/..:/work -w /work/demo mcr.microsoft.com/playwright:v1.56.0-noble /bin/bash -c 'npm install && npm run start & sleep 10 && npx playwright test --reporter=list ; kill %1 || true'",
    "test:e2e:docker:update": "docker run --rm -v $(pwd)/..:/work -w /work/demo mcr.microsoft.com/playwright:v1.56.0-noble /bin/bash -c 'npm install && npm run start & sleep 10 && npx playwright test --update-snapshots --reporter=list ; kill %1 || true'",
    "lint": "ng lint",
    "cap": "npm run build -- --configuration=production && cap copy"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.1",
    "@angular/common": "^21.2.1",
    "@angular/compiler": "^21.2.1",
    "@angular/core": "^21.2.1",
    "@angular/forms": "^21.2.1",
    "@angular/platform-browser": "^21.2.1",
    "@angular/platform-browser-dynamic": "^21.2.1",
    "@angular/router": "^21.2.1",
    "@capacitor/android": "^8.0.0",
    "@capacitor/app": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/haptics": "^8.0.0",
    "@capacitor/keyboard": "^8.0.0",
    "@capacitor/status-bar": "^8.0.0",
    "@ionic/angular": "^8.8.0",
    "@rdlabo/ionic-theme-ios26": "file:..",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.1",
    "@angular/language-service": "^21.2.1",
    "@capacitor/cli": "^8.0.0",
    "@ionic/angular-toolkit": "^12.0.0",
    "@playwright/test": "^1.57.0",
    "@rdlabo/eslint-plugin-rules": "^20.3.1",
    "angular-eslint": "21.2.0",
    "eslint": "^9.35.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsdoc": "^48.2.1",
    "eslint-plugin-prefer-arrow": "1.2.2",
    "jsdom": "^26.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "8.40.0",
    "vitest": "^4.0.0"
  },
  "description": "An Ionic project"
}
